# Copy this file to ".env" and fill in real values.
# .env is private and never committed to git.

# --- Telegram ---
# Get this from @BotFather in Telegram (use your @newgrain_dev_bot token for development)
BOT_TOKEN=

# Comma-separated Telegram user IDs that get access automatically on /start.
# Use this to grant YOURSELF access first: message the bot, it replies with your ID,
# paste it here, then restart the bot.
ADMIN_TG_IDS=

# --- Database (Postgres) ---
POSTGRES_USER=newgrain
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=newgrain
# How the apps reach the database inside docker compose:
DATABASE_URL=postgresql+asyncpg://newgrain:change-me-to-a-long-random-string@postgres:5432/newgrain

# --- Redis (conversation state + task queue) ---
REDIS_URL=redis://redis:6379/0

# --- Storage (S3 / MinIO for local dev) ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=newgrain
S3_SECRET_KEY=change-me-to-a-long-random-string
S3_BUCKET=newgrain-data-prod
S3_REGION=ru-central1

# --- Telegram API relay (Roskomnadzor workaround) ---
# Empty = talk to api.telegram.org directly (fine off-RU). On the prod RU server
# set this to the Cloudflare-Worker relay URL so the bot can reach Telegram.
TELEGRAM_API_BASE=

# --- CVAT Cloud (labeling pipeline: export/import/sync_labels) ---
CVAT_HOST=https://app.cvat.ai
CVAT_API_TOKEN=
CVAT_PROJECT_NAME=weeds-diseases-stress

# --- Yandex Cloud AI (SpeechKit = voice→text, YandexGPT = RU→EN translation) ---
# One API key for the newgrain-bot service account (roles ai.speechkit-stt.user
# + ai.languageModels.user). Folder ID is the b1g... id of your YC folder.
YC_API_KEY=
YC_FOLDER_ID=
YC_TRANSLATE_MODEL=yandexgpt
