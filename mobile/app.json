{
  "expo": {
    "name": "EAR",
    "slug": "flagleaf",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flagleaf",
    "userInterfaceStyle": "automatic",
    "updates": {
      "url": "https://ai.flagleaf.ru/api/ota/manifest",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "bundleIdentifier": "ru.flagleaf.ear",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Камера нужна, чтобы фотографировать растения для распознавания и ленты команды.",
        "NSPhotoLibraryUsageDescription": "Доступ к галерее нужен, чтобы отправлять фото растений в ленту команды.",
        "NSPhotoLibraryAddUsageDescription": "Снимки из камеры EAR сохраняются в вашу галерею.",
        "NSMicrophoneUsageDescription": "Микрофон нужен для записи видео с голосовым комментарием."
      }
    },
    "android": {
      "package": "ru.flagleaf.ear",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#faf8f4",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 76
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "321be4ac-aae0-4fb9-8c8b-58326d098eae"
      }
    },
    "owner": "akhaliullin"
  }
}
